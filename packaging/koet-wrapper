#!/usr/bin/env bash
# /usr/bin/koet-ui — wrapper installed by the package
# Starts the KOET web UI backend server using the bundled venv.

set -euo pipefail

INSTALL_DIR="/usr/lib/koet"
VENV="$INSTALL_DIR/venv"
SERVER="$INSTALL_DIR/koet-server.py"
PORT="${PORT:-5002}"

if [[ ! -f "$SERVER" ]]; then
    echo "ERROR: $SERVER not found — is koet installed correctly?" >&2
    exit 1
fi

# Use the package venv if available; fall back to system python3
if [[ -x "$VENV/bin/python3" ]]; then
    PYTHON="$VENV/bin/python3"
else
    PYTHON="python3"
    echo "WARNING: venv not found at $VENV — using system python3" >&2
fi

echo ""
echo "KOET Web UI — backend server"
echo "  URL  : http://127.0.0.1:$PORT"
echo "  Tunnel (from workstation): ssh -L ${PORT}:127.0.0.1:${PORT} $(whoami)@$(hostname -f 2>/dev/null || hostname)"
echo "  Stop : Ctrl+C  or  systemctl stop koet"
echo ""

PORT="$PORT" exec "$PYTHON" "$SERVER"
